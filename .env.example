# Copy to .env and adjust. NEVER commit a real .env.
# Everything below has an offline-safe default; you only need real values to
# exercise the optional real adapters.

# ---- App ----
AIH_ENV=local
AIH_LOG_LEVEL=INFO
AIH_RUN_LEDGER_PATH=./run_ledger.sqlite3

# ---- LLM ----
# Provider: "fake" (default, deterministic, offline), "anthropic", or "openai".
AIH_LLM_PROVIDER=fake
# Only used when AIH_LLM_PROVIDER=anthropic
AIH_ANTHROPIC_API_KEY=
AIH_ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# Only used when AIH_LLM_PROVIDER=openai
AIH_OPENAI_API_KEY=
AIH_OPENAI_MODEL=gpt-4o-mini

# ---- Embeddings ----
# Embedder: "hash" (default, deterministic, offline) or "anthropic"/"openai".
AIH_EMBEDDER=hash
AIH_EMBEDDING_DIM=256
AIH_VECTOR_BACKEND=memory
AIH_RERANKER=fake
AIH_ENABLE_QUERY_REWRITE=true
AIH_ENABLE_RAG_SAFETY=true

# ---- Agent ----
AIH_AGENT_MAX_STEPS=8
AIH_AGENT_TOKEN_BUDGET=8000
AIH_AGENT_ENABLE_MEMORY=true
AIH_ONLINE_EVAL_SAMPLE_RATE=0.0
AIH_MOCK_API_BASE_URL=http://127.0.0.1:9000

# ---- Connector credentials (point at the mock APIs by default) ----
AIH_PULSEADS_TOKEN=pulse-demo-token
AIH_NOVAREACH_API_KEY=nova-demo-key
AIH_CREATIVEBOX_USER=creativebox
AIH_CREATIVEBOX_PASSWORD=creativebox-secret

# ---- AWS / LocalStack (Phase 8) ----
AWS_ENDPOINT_URL=http://127.0.0.1:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AIH_S3_CREATIVES_BUCKET=aih-creatives
AIH_SQS_APPROVALS_QUEUE=aih-approvals
